NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/securemessenger
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# В development любые LAN-IP на порту 3333 разрешены автоматически
CORS_ORIGINS=http://localhost:3333,http://127.0.0.1:3333

# Порт 5000: не запускайте npm run dev и docker backend одновременно
# docker stop secure-messenger-backend
LOG_LEVEL=debug
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# TURN_URLS=turn:your-turn.example.com:3478
# TURN_USERNAME=
# TURN_CREDENTIAL=
