{
    "name": "secure-messenger-client",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "clean:vite": "node scripts/clean-vite-cache.mjs",
        "dev": "npm run clean:vite && concurrently -n http,https -c blue,magenta \"node --disable-warning=DEP0060 ./node_modules/vite/bin/vite.js\" \"node --disable-warning=DEP0060 ./node_modules/vite/bin/vite.js --config vite.config.https.js\"",
        "dev:http": "node --disable-warning=DEP0060 ./node_modules/vite/bin/vite.js",
        "dev:https": "node --disable-warning=DEP0060 ./node_modules/vite/bin/vite.js --config vite.config.https.js",
        "dev:public": "concurrently -n dev,pub,tunnel -c blue,yellow,green \"npm run dev\" \"node scripts/tunnel-serve.mjs\" \"node scripts/dev-tunnel.mjs\"",
        "build": "vite build",
        "preview": "vite preview"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^6.5.2",
        "@fortawesome/free-solid-svg-icons": "^6.5.2",
        "@fortawesome/react-fontawesome": "^0.2.2",
        "@tanstack/react-virtual": "^3.13.23",
        "axios": "^1.5.0",
        "clsx": "^2.0.0",
        "date-fns": "^2.30.0",
        "lucide-react": "^0.279.0",
        "marked": "^12.0.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "socket.io-client": "^4.7.2",
        "tailwind-merge": "^1.14.0",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@vitejs/plugin-basic-ssl": "^1.1.0",
        "@vitejs/plugin-react": "^4.0.3",
        "autoprefixer": "^10.4.15",
        "concurrently": "^9.2.1",
        "localtunnel": "^2.0.2",
        "postcss": "^8.4.29",
        "tailwindcss": "^3.3.3",
        "vite": "^4.4.5"
    }
}
